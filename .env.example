# ===========================================
# LearnHub Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values.

# --- Database ---
DB_URL=jdbc:postgresql://localhost:5432/capstone
DB_USERNAME=postgres
DB_PASSWORD=your_password

# --- Server ---
SERVER_PORT=8080

# --- JWT ---
JWT_SECRET=your-jwt-secret-key
JWT_EXPIRATION_MS=86400000

# --- Email (SMTP) ---
MAILER_PASSWORD=your-mailer-password
MAILER_USERNAME=your-email@gmail.com
MAIL_FROM=your-email@gmail.com

# --- Password Reset ---
RESET_PASSWORD_COUNT=10
PASSWORD_RESET_BASE_URL=http://localhost:8080
PASSWORD_RESET_EXPIRY_HOURS=1

# --- Email Verification ---
VERIFICATION_BASE_URL=http://localhost:8080
VERIFICATION_TOKEN_EXPIRY_HOURS=24

# --- Roles ---
DEFAULT_ROLE_ID=2
